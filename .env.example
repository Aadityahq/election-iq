# ========================================
# ElectionIQ Environment Variables
# ========================================
# 
# Copy this file to .env.local and fill in your API keys.
# DO NOT commit .env.local to Git (it contains secrets!)
# 
# ========================================

# ========================================
# 1. GOOGLE GEMINI API
# ========================================
# Used for: AI-powered conversational responses about elections
# Get your key:
#   1. Go to https://console.cloud.google.com
#   2. Create a new project or select existing
#   3. Enable "Generative Language API"
#   4. Go to Credentials → Create Credentials → API Key
#   5. Copy and paste below
#
VITE_GEMINI_API_KEY=your_gemini_api_key_here


# ========================================
# 2. GOOGLE MAPS API
# ========================================
# Used for: Polling location finder (nearby stations map)
# Get your key:
#   1. Same Cloud Console as Gemini
#   2. Enable "Maps JavaScript API"
#   3. Create API Key → Restrict to JavaScript applications
#   4. Copy and paste below
#
# IMPORTANT: Restrict key to JavaScript origins in Console for security!
#
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here


# ========================================
# 3. FIREBASE CONFIGURATION
# ========================================
# Used for: Real-time database (Firestore), analytics, authentication
# Get your config:
#   1. Go to https://console.firebase.google.com
#   2. Create a new project or select existing
#   3. Click "Add app" → Web
#   4. Copy the config object below
#

# Firebase Web API Key
VITE_FIREBASE_API_KEY=your_firebase_api_key

# Your Firebase project auth domain (e.g., myproject.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Your Firebase project ID
VITE_FIREBASE_PROJECT_ID=your_project_id

# Firebase storage bucket (e.g., myproject.appspot.com)
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Firebase messaging sender ID (numeric ID from project settings)
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id

# Firebase app ID (e.g., 1:123456789:web:abcdef123456)
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Measurement ID for analytics (e.g., G-XXXXXXXXXX)
# Optional: leave blank if analytics not enabled
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id


# ========================================
# SECURITY NOTES
# ========================================
# 
# 1. These keys are FRONTEND keys (it's safe to expose them)
#    - Gemini API key is rate-limited per IP
#    - Maps API key is restricted to JavaScript origins
#    - Firebase keys are restricted by Firestore rules
# 
# 2. Never commit .env.local to Git
#    - It's in .gitignore already
#    - But double-check before pushing!
# 
# 3. In production (Cloud Run, Firebase Hosting)
#    - Set these as environment variables in deployment
#    - Use Cloud Run secrets or Firebase environment config
# 
# 4. If a key is compromised:
#    - Regenerate it immediately in the respective console
#    - Update .env.local
#    - Redeploy the app
#
# ========================================
